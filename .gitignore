# .gitignore

# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Data (large files — use DVC or Git LFS instead) ──────────────────────────
data/raw/
data/processed/

# ── Model weights (large files — store on HuggingFace Hub / GDrive) ──────────
models/saved/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Test cache ────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IMPORTANT: Never commit a nested .git folder ──────────────────────────────
*.git/
